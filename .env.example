# ============ Database (Postgres) ============
POSTGRES_USER=aihelp
POSTGRES_PASSWORD=change_me_strong_db_password
POSTGRES_DB=aihelp
# DATABASE_URL dùng chung cho web (Drizzle/Better Auth) và api. Host "db" = service trong docker compose.
DATABASE_URL=postgresql://aihelp:change_me_strong_db_password@db:5432/aihelp

# ============ Encryption (CRITICAL) ============
# Master key bọc khóa mã hóa SSH credential. 32 bytes ngẫu nhiên, base64.
# Sinh bằng: openssl rand -base64 32
# MẤT key = không giải mã được creds. LỘ key = lộ toàn bộ creds. Giữ trong secret manager.
APP_MASTER_KEY=REPLACE_WITH_openssl_rand_base64_32

# ============ Internal service auth (web <-> api) ============
# Shared secret để web gọi api trên mạng private. Sinh: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=REPLACE_WITH_openssl_rand_hex_32
# URL api nội bộ (web gọi). Trong compose: http://api:8000
API_BASE_URL=http://api:8000

# ============ Better Auth (web) ============
BETTER_AUTH_SECRET=REPLACE_WITH_openssl_rand_hex_32
BETTER_AUTH_URL=http://localhost:3000

# ============ First admin (seed lần đầu, invite-only) ============
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change_me_admin_password

# ============ LLM (AI agent, dùng ở api) ============
# provider: "openai" (OpenAI-compatible) hoặc "anthropic"
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048

# ============ Notifications (api/worker) ============
# Email (SMTP) - dùng cho invite + cảnh báo
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
# Telegram (tuỳ chọn) - cảnh báo
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============ ChatOps (Telegram 2 chiều, tuỳ chọn) ============
# Bí mật nằm trong URL webhook Telegram (chỉ Telegram biết URL này). Sinh: openssl rand -hex 16
TELEGRAM_WEBHOOK_SECRET=
# URL HTTPS công khai của web (để Telegram gọi webhook). Vd: https://chat.example.com
# Webhook = ${PUBLIC_BASE_URL}/api/webhooks/telegram/${TELEGRAM_WEBHOOK_SECRET}
PUBLIC_BASE_URL=

# ============ Monitoring worker ============
MONITOR_INTERVAL_SECONDS=60

# ============ Agent gateway (Local Agent connection, tuỳ chọn) ============
# Bí mật ký token enroll cho agent (api ký, gateway verify). Sinh: openssl rand -hex 32
AGENT_SECRET=
# URL gateway công khai để agent dial-out tới (vd https://gw.example.com hoặc http://IP:8090)
GATEWAY_PUBLIC_URL=
# URL gateway nội bộ để api gọi /dispatch (trong compose: http://gateway:8090)
GATEWAY_INTERNAL_URL=http://gateway:8090
